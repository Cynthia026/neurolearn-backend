# Base de datos — en Render usar la URL que te dan
DATABASE_URL="mysql://usuario:password@host:3306/neurolearn"

# JWT — cambia esto por una cadena larga y segura
JWT_SECRET="cambia-esto-por-algo-muy-seguro-en-produccion"

# Servidor
PORT=3000
NODE_ENV=production

# CORS — agrega tu URL de Vercel aquí después de desplegar
ALLOWED_ORIGINS="https://tu-proyecto.vercel.app,http://localhost:5500"
